# Quality/"prod-mirror" path: route through the LiteLLM gateway.
# Free local embeddings + Claude for the answer. Copy to .env and paste your key.
#   cp .env.gateway.example .env   (then fill OPENAI_API_KEY)
OPENAI_BASE_URL=http://127.0.0.1:4000
OPENAI_API_KEY=<paste LITELLM_MASTER_KEY from /opt/ai-lab/.env on the Alienware>
EMBED_MODEL=embed
CHAT_MODEL=claude

# Use the AI Lab Qdrant service for shared vector storage.
SB_STORE=qdrant
SB_COLLECTION=second_brain
SB_MEMORY_DIR=./data/memory
SB_STATE_DB=./data/artjeck.sqlite3
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=<paste QDRANT_API_KEY from /opt/ai-lab/.env on the Alienware>
