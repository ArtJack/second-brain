# Default: talk DIRECTLY to the Alienware GTX Ollama (free, no key, both models warm).
# Copy to .env. Switch to .env.gateway for the Claude-quality path (see .env.gateway.example).
OPENAI_BASE_URL=http://192.168.1.159:11434/v1
OPENAI_API_KEY=ollama
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3.1:8b

# Store backend. Chroma is local/on-disk; qdrant uses the AI Lab vector DB.
SB_STORE=chroma
SB_DATA=./data/chroma
SB_MEMORY_DIR=./data/memory
SB_STATE_DB=./data/artjeck.sqlite3
SB_COLLECTION=second_brain

# Required only when SB_STORE=qdrant.
QDRANT_URL=http://192.168.1.159:6333
QDRANT_API_KEY=

# Retrieval tuning (optional)
SB_CHUNK_SIZE=1200
SB_CHUNK_OVERLAP=150
SB_TOP_K=5
